---
import reviews from '../data/reviews.json';
---

<div class="authority-strip" aria-label="Client testimonials">
  <div class="authority-fade authority-fade-left"></div>
  <div class="authority-fade authority-fade-right"></div>

  <div class="authority-track">
    {[...reviews, ...reviews].map((review, index) => (
<article class="authority-card" aria-label={`Testimonial ${index + 1}`}>
  <div class="authority-stars" aria-hidden="true">★★★★★</div>
  <p class="authority-quote">“{review}”</p>
</article>
    ))}
  </div>
</div>

<style>

.authority-strip {
  position: relative;
  width: 100%;
  overflow: hidden;
  padding: 1rem 0;
  background-color: transparent;

}

.authority-track {
  display: flex;
  align-items: center;
  gap: 1rem;
  width: max-content;
  animation: authorityMarquee 200s linear infinite;
  background-color: transparent;
}

.authority-card {
  flex: 0 0 auto;
  width: min(32rem, 82vw);
  min-height: 1rem;
  padding: 1.5rem 1.5rem;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  border: 1px solid rgba(78, 120, 82, 0.22);
  border-radius: 1.25rem;
  background:linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.28));
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  box-shadow:
    0 10px 30px rgba(56, 44, 28, 0.08),
    inset 0 1px 0 rgba(255, 255, 255, 0.45);
  transition:
    transform 0.35s ease,
    box-shadow 0.35s ease,
    border-color 0.35s ease,
    background 0.35s ease;
}

.authority-card:hover {
  transform: translateY(-2px);
  border-color: rgba(120, 105, 78, 0.32);
  box-shadow:
    0 16px 36px rgba(56, 44, 28, 0.12),
    inset 0 1px 0 rgba(255, 255, 255, 0.5);
}

.authority-quote {
  margin: 0;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 1rem;
  line-height: 1.6;
  color: var(--text);
}



.authority-strip:hover .authority-track {
  animation-play-state: paused;
}

@keyframes authorityMarquee {
  from {
    transform: translateX(0);
  }
  to {
    transform: translateX(calc(-50% - 0.5rem));
  }
}

@media (max-width: 720px) {
  .authority-strip {
    padding: 1rem 0;
  }

  .authority-track {
    gap: 0.8rem;
    animation-duration: 200s;
  }

  .authority-card {
    width: 84vw;
    min-height: 8rem;
    padding: 1.1rem 1rem;
  }

  .authority-quote {
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .authority-fade {
    width: 2.25rem;
  }
}

@media (prefers-reduced-motion: reduce) {
  .authority-track {
    animation: none;
  }
}
</style>