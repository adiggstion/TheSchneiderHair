---
import '../styles/global.css';
---

<div class="brand-mark text-center md:text-left">
  <span class="brand-mark-text">theschneider.hair</span>
</div>

<style>
.brand-mark {
  width: 100%;
  background-color: var(--color-beige-200);
  overflow: hidden;
}

.brand-mark-text {
  display: inline-block;
  font-size: 1.5rem;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: #000;

  opacity: 0;
  transform: translateX(120px);
  animation: brandSlideIn 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  will-change: transform, opacity;
}

@keyframes brandSlideIn {
  from {
    opacity: 0;
    transform: translateX(120px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}
</style>